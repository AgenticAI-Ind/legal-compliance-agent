# Legal & Compliance Agent Environment Variables
# Copy this file to .env and update with your values

# ===== Application =====
ENVIRONMENT=development
PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-in-production

# ===== Database =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legal_compliance
DATABASE_NAME=legal_compliance
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Database Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
SQL_ECHO=false

# ===== ChromaDB =====
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=~/.legal-compliance-agent/chroma

# ===== OpenAI API =====
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.1

# ===== Alternative: Use Ollama for local LLMs =====
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# ===== Security =====
# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== Redis (Caching & Rate Limiting) =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

# ===== Rate Limiting =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ===== File Upload =====
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,docx,txt
UPLOAD_DIR=./data/uploads

# ===== Document Processing =====
MAX_DOCUMENT_LENGTH=1000000
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ===== Compliance Settings =====
DEFAULT_COMPLIANCE_FRAMEWORKS=gdpr,ccpa
STRICT_COMPLIANCE_MODE=false

# ===== Monitoring & Telemetry =====
ENABLE_TELEMETRY=false
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# ===== Logging =====
LOG_FORMAT=json
LOG_FILE=./logs/legal-compliance.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# ===== Feature Flags =====
ENABLE_PDF_UPLOAD=true
ENABLE_DOCUMENT_COMPARISON=true
ENABLE_POLICY_GENERATION=true
ENABLE_RAG_QA=true

# ===== API Keys (Third-party services) =====
# ANTHROPIC_API_KEY=your-anthropic-key
# COHERE_API_KEY=your-cohere-key
# HUGGINGFACE_API_KEY=your-huggingface-key

# ===== Email Notifications (Optional) =====
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@legal-compliance-agent.com

# ===== Webhook Notifications (Optional) =====
# WEBHOOK_URL=https://your-webhook-url.com/notifications
# WEBHOOK_SECRET=your-webhook-secret

# ===== Development Settings =====
DEBUG=false
RELOAD=true
WORKERS=4

# ===== Docker Settings =====
BUILD_TARGET=production
API_PORT=8000
GRAFANA_PASSWORD=admin

# ===== Backup Settings =====
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_RETENTION_DAYS=30
# BACKUP_DIR=./backups
